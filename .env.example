# Database
DATABASE_URL=postgresql+asyncpg://cml:cml_dev_password@localhost:5432/cml_db

# Security
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Email (Sparkpost)
SPARKPOST_API_KEY=your-sparkpost-api-key
SPARKPOST_FROM_EMAIL=noreply@choosemylawyer.co.uk
SPARKPOST_FROM_NAME=Choose My Lawyer

# Google Places API
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Fetchify (UK postcode lookup)
FETCHIFY_API_KEY=your-fetchify-api-key

# App config
ENVIRONMENT=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Review settings
REVIEW_INVITATION_DELAY_DAYS=90
REVIEW_INVITATION_EXPIRY_DAYS=30

# Rate limiting
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_LOGIN=5
